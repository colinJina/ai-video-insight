{
  "python.defaultInterpreterPath": "${workspaceFolder}\\python-backend\\.venv\\Scripts\\python.exe",
  "python.analysis.extraPaths": ["${workspaceFolder}\\python-backend"],
  "python.analysis.typeCheckingMode": "basic",
  "editor.formatOnSave": true,
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff"
  },
  "files.exclude": {
    "**/__pycache__": true
  }
}
